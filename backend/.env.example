# MongoDB Connection String
# Get from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL= add_your_mongodb_connection_string_here
MONGODB_DB=meridian

# VideoDB API Key
# Get from: https://console.videodb.io
VIDEODB_API_KEY=add_your_videodb_api_key_here
VIDEODB_API_ENDPOINT=https://api.videodb.io
VIDEODB_WEBHOOK_SECRET=add_your_webhook_secret_here

# Anthropic/Claude API Key (optional)
ANTHROPIC_API_KEY=add_your_anthropic_api_key_here

# Groq API Key
# Get from: https://console.groq.com
GROQ_API_KEY=add_your_groq_api_key_here

# Application Settings
APP_NAME=Meridian
ENVIRONMENT=development
DEBUG=true

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30

# ngrok Tunnel URL
# Get from running: ngrok http 8000
CALLBACK_BASE_URL=add_your_ngrok_url_here

# Processing Configuration
MAX_WORKERS=4
TRANSCRIPT_BATCH_TIMEOUT_SECONDS=5
